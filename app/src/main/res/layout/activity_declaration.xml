<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/button_style"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ajouter déclaration"
            android:textColor="@android:color/white"
            android:textSize="20sp" />

    </androidx.appcompat.widget.Toolbar>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="475dp"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:padding="40dp">

        <ImageView
            android:id="@+id/imageView"
            android:layout_width="432dp"
            android:layout_height="200dp"
            android:layout_gravity="center_horizontal" />

        <EditText
            android:id="@+id/declarationInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Entrez votre déclaration ici" />

        <Button
            android:id="@+id/button"
            android:layout_width="300dp"
            android:layout_height="40dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/button_style"
            android:text="Ajouter déclaration"
            android:textColor="#FFFFFF" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="40dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/takePhotoButton"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_marginEnd="60dp"
            android:background="@null"
            android:scaleType="fitCenter"
            android:src="@drawable/camera" /> <!-- Remplacer par l'icône appropriée -->

        <ImageButton
            android:id="@+id/uploadPhotoButton"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:background="@null"
            android:scaleType="fitCenter"
            android:src="@drawable/picture" /> <!-- Remplacer par l'icône appropriée -->

    </LinearLayout>
</RelativeLayout>
