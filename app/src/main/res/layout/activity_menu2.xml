<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/my_background_image">

    <ImageView
        android:id="@+id/image1"
        android:layout_width="207dp"
        android:layout_height="171dp"
        android:src="@mipmap/dp"
        app:layout_constraintBottom_toTopOf="@+id/image3"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toStartOf="@+id/image2"
        app:layout_constraintHorizontal_chainStyle="spread_inside"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.974" />

    <ImageView
        android:id="@+id/image2"
        android:layout_width="212dp"
        android:layout_height="177dp"
        android:layout_marginStart="4dp"
        android:src="@mipmap/appar"
        app:layout_constraintBottom_toTopOf="@+id/image4"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintStart_toEndOf="@+id/image1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="1.0" />

    <ImageView
        android:id="@+id/image3"
        android:layout_width="224dp"
        android:layout_height="177dp"
        android:layout_marginBottom="188dp"
        android:src="@mipmap/app"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toStartOf="@+id/image4"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/image4"
        android:layout_width="204dp"
        android:layout_height="173dp"
        android:layout_marginStart="8dp"
        android:layout_marginBottom="188dp"
        android:src="@mipmap/st"
        app:layout_constraintBottom_toBottomOf="parent"

        app:layout_constraintStart_toEndOf="@+id/image3" />

</androidx.constraintlayout.widget.ConstraintLayout>
