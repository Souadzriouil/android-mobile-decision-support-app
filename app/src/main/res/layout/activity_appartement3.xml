<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".appartementActivity"
    android:background="#D4E5F7"

    >

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:layout_editor_absoluteX="0dp"
        tools:layout_editor_absoluteY="124dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="400dp"
                android:layout_height="197dp">

                <TextView
                    android:id="@+id/textView7"
                    android:layout_width="194dp"
                    android:layout_height="162dp"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="@font/aldrich"
                    android:gravity="center"
                    android:text="@string/votre_appartement"
                    android:textColor="#5B87E4"
                    android:textSize="25sp"
                    app:layout_constraintBottom_toBottomOf="@+id/imageView17"
                    app:layout_constraintEnd_toStartOf="@+id/imageView17"
                    app:layout_constraintTop_toTopOf="@+id/imageView17"
                    app:layout_constraintVertical_bias="0.478"
                    tools:ignore="MissingConstraints,TextSizeCheck" />

                <ImageView
                    android:id="@+id/imageView17"
                    android:layout_width="220dp"
                    android:layout_height="139dp"
                    android:layout_marginStart="200dp"
                    android:contentDescription="TODO"
                    app:layout_constraintStart_toStartOf="parent"
                    app:srcCompat="@drawable/hahir"
                    tools:ignore="MissingConstraints"
                    tools:layout_editor_absoluteY="6dp" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout

                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="20dp"
                android:background="@drawable/intro_top_background"
                android:orientation="vertical"
                android:padding="8dp">

                <CheckBox
                    android:id="@+id/parkingCheckbox"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:buttonTint="@android:color/white"
                    android:minHeight="48dp"
                    android:text="Parking"
                    android:textColor="@color/white"
                    android:textSize="20dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:ignore="MissingConstraints" />

                <CheckBox
                    android:id="@+id/balconCheckbox"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="4dp"
                    android:buttonTint="@android:color/white"
                    android:minHeight="48dp"
                    android:text="Balcon"
                    android:textColor="@color/white"
                    android:textSize="20dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/parkingCheckbox" />

                <CheckBox
                    android:id="@+id/cuisineCheckbox"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="12dp"
                    android:minHeight="48dp"
                    android:text="Cuisine équipée"
                    android:textColor="@color/white"
                    android:textSize="20dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:buttonTint="@android:color/white"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/balconCheckbox" />

                <Button
                    android:id="@+id/next_button"
                    android:layout_width="267dp"
                    android:layout_height="39dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/next_button_bg"
                    android:drawableEnd="@drawable/ic_arrow_forward"
                    android:text=""
                    android:textColor="@color/white" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
